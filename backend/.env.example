# Primary: OpenRouter (get key at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your_key_here
OPENROUTER_MODEL=openrouter/free

# Per-agent models (matching SapBit/agentic-document-assistant)
DOCUMENT_MODEL=meta-llama/llama-3.2-3b-instruct
SUMMARY_MODEL=google/gemma-3-4b-it
INFO_MODEL=deepseek/deepseek-r1

# Fallback: Groq (optional, get key at https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_groq_key_here

# Server
HOST=0.0.0.0
PORT=8000
